{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benedictjohannes/crobe/playbook/playbook",
  "$defs": {
    "Assertion": {
      "properties": {
        "code": {
          "type": "string",
          "minLength": 3,
          "description": "Unique code for the assertion"
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "description": "Title of the assertion"
        },
        "description": {
          "type": "string",
          "minLength": 3,
          "description": "Detailed description of what is being checked"
        },
        "preCmds": {
          "items": {
            "$ref": "#/$defs/Exec"
          },
          "type": "array",
          "description": "Executions before main commands. Data gathered here persists for the whole assertion."
        },
        "cmds": {
          "items": {
            "$ref": "#/$defs/Cmd"
          },
          "type": "array",
          "minItems": 1,
          "description": "Main command units to execute. At least one required."
        },
        "postCmds": {
          "items": {
            "$ref": "#/$defs/Exec"
          },
          "type": "array",
          "description": "Executions after all main commands settle."
        },
        "minPassingScore": {
          "type": "integer",
          "description": "Minimum score to consider assertion as passed (Default: 1)",
          "default": 1
        },
        "passDescription": {
          "type": "string",
          "minLength": 3,
          "description": "Message shown if the assertion passes"
        },
        "failDescription": {
          "type": "string",
          "minLength": 3,
          "description": "Message shown if the assertion fails"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "code",
        "title",
        "description",
        "cmds",
        "passDescription",
        "failDescription"
      ]
    },
    "Cmd": {
      "properties": {
        "exec": {
          "$ref": "#/$defs/Exec",
          "description": "Execution details"
        },
        "passScore": {
          "type": "integer",
          "description": "Score added if evaluation passes (Default: 1)",
          "default": 1
        },
        "failScore": {
          "type": "integer",
          "description": "Score added if evaluation fails (Default: -1)",
          "default": -1
        },
        "stdOutRule": {
          "$ref": "#/$defs/EvaluationRule",
          "description": "Rule for stdout evaluation. Takes precedence over exitCodeRules if result is -1 or 1."
        },
        "stdErrRule": {
          "$ref": "#/$defs/EvaluationRule",
          "description": "Rule for stderr evaluation. Takes absolute precedence over stdOutRule if result is -1 or 1."
        },
        "exitCodeRules": {
          "items": {
            "$ref": "#/$defs/ExitCodeRule"
          },
          "type": "array",
          "description": "Rules for exit code evaluation. Evaluated only if stdOutRule and stdErrRule are neutral."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "exec"
      ]
    },
    "EvaluationRule": {
      "properties": {
        "regex": {
          "type": "string",
          "description": "Regex to match against output"
        },
        "includeStdErr": {
          "type": "boolean",
          "description": "Include stderr in regex evaluation",
          "default": false
        },
        "func": {
          "type": "string",
          "description": "JS function for evaluation. Takes precedence over regex. Signature: (stdout, stderr, assertionContext) =\u003e -1 | 0 | 1"
        },
        "funcFile": {
          "type": "string",
          "description": "Path to JS/TS file. BUILDER ONLY: using this in real playbook will cause error."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Exec": {
      "properties": {
        "shell": {
          "type": "string",
          "description": "Shell/Interpreter to use (eg: bash, powershell, sh). Optional. Defaults: pwsh (windows, falls back to powershell if not found), zsh (mac), bash (linux and others). Note that for bash and powershell, set -o pipefail and $ErrorActionPreference = 'Stop' is added to catch execution errors. Non-shell interpreters like python3 or node are supported. Set to ! to directly execute the script as cmd and args, executed directly (eg: ls -lah)."
        },
        "script": {
          "type": "string",
          "description": "Script to execute"
        },
        "scriptFileExtension": {
          "type": "string",
          "description": "Extension for the temporary script file (eg: sh, ps1, py, js). Optional. If not specified, defaults to 'sh' for bash/sh/zsh, 'ps1' for powershell/pwsh, and empty for others."
        },
        "func": {
          "type": "string",
          "description": "Embedded JS code that returns the script to be executed. Takes precedence over script. Signature: ({ assertionContext, env, os, arch, user, cwd }) =\u003e string."
        },
        "funcFile": {
          "type": "string",
          "description": "Path to JS/TS file. BUILDER ONLY: using this in real playbook will cause error."
        },
        "gather": {
          "items": {
            "$ref": "#/$defs/GatherSpec"
          },
          "type": "array",
          "description": "Data extraction specs"
        },
        "excludeFromReport": {
          "type": "boolean",
          "description": "Hide stdout/stderr results from log and markdown report"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ExitCodeRule": {
      "properties": {
        "min": {
          "type": "integer",
          "description": "Minimum exit code (inclusive)"
        },
        "max": {
          "type": "integer",
          "description": "Maximum exit code (inclusive)"
        },
        "result": {
          "type": "integer",
          "description": "Score result: -1 (Fail), 0 (Neutral), 1 (Pass). The first matching rule wins."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "result"
      ]
    },
    "GatherSpec": {
      "properties": {
        "key": {
          "type": "string",
          "description": "Key in context"
        },
        "excludeFromReport": {
          "type": "boolean",
          "description": "Hide key from JSON report"
        },
        "regex": {
          "type": "string",
          "description": "Regex to extract data"
        },
        "includeStdErr": {
          "type": "boolean",
          "description": "Include stderr in regex evaluation",
          "default": false
        },
        "func": {
          "type": "string",
          "description": "JS function for extraction. Takes precedence over regex. Signature: (stdout, stderr, assertionContext) =\u003e string"
        },
        "funcFile": {
          "type": "string",
          "description": "Path to JS/TS file. BUILDER ONLY: using this in real playbook will cause error."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "key"
      ]
    },
    "ReportDestinationConfig": {
      "properties": {
        "url": {
          "type": "string",
          "description": "URL to post report content to"
        },
        "format": {
          "type": "string",
          "enum": [
            "multipart",
            "json"
          ],
          "description": "Format of the report (json|multipart)",
          "default": "multipart"
        },
        "signatureSecret": {
          "type": "string",
          "description": "Secret for HMAC-SHA256 signature"
        },
        "additionalHeaders": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "Custom headers for the request"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "url"
      ]
    },
    "Section": {
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3,
          "description": "Title of the section"
        },
        "description": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "minItems": 1,
          "description": "List of descriptions for the section"
        },
        "assertions": {
          "items": {
            "$ref": "#/$defs/Assertion"
          },
          "type": "array",
          "minItems": 1,
          "description": "List of assertions within this section"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "title",
        "description",
        "assertions"
      ]
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "description": "Title of the report"
    },
    "reportFrontmatter": {
      "type": "object",
      "description": "Custom metadata merged into the generated markdown report frontmatter."
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/Section"
      },
      "type": "array",
      "minItems": 1,
      "description": "Logical groups of assertions."
    },
    "reportDestination": {
      "type": "string",
      "enum": [
        "folder",
        "https"
      ],
      "description": "Destination for the report (folder|https)",
      "default": "folder"
    },
    "reportDestinationFolder": {
      "type": "string",
      "description": "Folder path if reportDestination is 'folder'. Defaults to 'reports'."
    },
    "reportDestinationHttps": {
      "$ref": "#/$defs/ReportDestinationConfig",
      "description": "Required if reportDestination is 'https'."
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "title",
    "sections"
  ]
}
